{
  "name": "random-x",
  "version": "1.1.0",
  "description": "Zero-dependency seeded PRNG utilities — shuffle, sample, weighted pick, gaussian, and more",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./cli.js": "./src/cli.js"
  },
  "bin": {
    "random-x": "./src/cli.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:core": "node --test test/index.test.js",
    "test:coverage": "c8 --reporter=text node --test test/*.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "random",
    "prng",
    "seeded",
    "shuffle",
    "fisher-yates",
    "weighted",
    "gaussian",
    "mulberry32",
    "xorshift",
    "sampling"
  ],
  "license": "MIT",
  "author": "sulthonzh",
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/random-x.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
